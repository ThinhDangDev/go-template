project_name: {{.Name}}

before:
  hooks:
    - go mod tidy

builds:
  - main: ./cmd/main.go
    binary: {{.Name}}
    env:
      - CGO_ENABLED=0
    goos:
      - linux
      - darwin
      - windows
    goarch:
      - amd64
      - arm64

archives:
  - format_overrides:
      - goos: windows
        format: zip

checksum:
  name_template: checksums.txt

changelog:
  disable: true
