func TestUserUsecase_Create(t *testing.T) {
	t.Run("success", func(t *testing.T) {
		mockRepo := new(MockUserRepository)
		uc := usecase.NewUserUsecase(mockRepo)

		input := &entity.User{
			Email:    "test@example.com",
			Password: "password123",
			Name:     "Test User",
		}

		// Email doesn't exist
		mockRepo.On("GetByEmail", mock.Anything, input.Email).Return(nil, nil)
		// Create succeeds
		mockRepo.On("Create", mock.Anything, mock.AnythingOfType("*entity.User")).Return(nil)

		err := uc.Create(context.Background(), input)

		require.NoError(t, err)
		assert.Equal(t, input.Email, "test@example.com")
		assert.Equal(t, input.Name, "Test User")
		assert.NotEqual(t, input.Password, "password123")
		assert.NoError(t, bcrypt.CompareHashAndPassword([]byte(input.Password), []byte("password123")))
		mockRepo.AssertExpectations(t)
	})

	t.Run("email already exists", func(t *testing.T) {
		mockRepo := new(MockUserRepository)
		uc := usecase.NewUserUsecase(mockRepo)

		existingUser := &entity.User{
			ID:    uuid.New(),
			Email: "test@example.com",
		}

		input := &entity.User{
			Email:    "test@example.com",
			Password: "password123",
			Name:     "Test User",
		}

		mockRepo.On("GetByEmail", mock.Anything, input.Email).Return(existingUser, nil)

		err := uc.Create(context.Background(), input)

		assert.ErrorIs(t, err, usecase.ErrEmailAlreadyExists)
		mockRepo.AssertExpectations(t)
	})
}

func TestUserUsecase_GetByID(t *testing.T) {
	t.Run("found", func(t *testing.T) {
		mockRepo := new(MockUserRepository)
		uc := usecase.NewUserUsecase(mockRepo)

		userID := uuid.New()
		expectedUser := &entity.User{
			ID:    userID,
			Email: "test@example.com",
			Name:  "Test User",
		}

		mockRepo.On("GetByID", mock.Anything, userID).Return(expectedUser, nil)

		user, err := uc.GetByID(context.Background(), userID)

		require.NoError(t, err)
		assert.Equal(t, expectedUser, user)
		mockRepo.AssertExpectations(t)
	})

	t.Run("not found", func(t *testing.T) {
		mockRepo := new(MockUserRepository)
		uc := usecase.NewUserUsecase(mockRepo)

		userID := uuid.New()
		mockRepo.On("GetByID", mock.Anything, userID).Return(nil, nil)

		user, err := uc.GetByID(context.Background(), userID)

		assert.Nil(t, user)
		assert.NoError(t, err)
		mockRepo.AssertExpectations(t)
	})
}

func TestUserUsecase_List(t *testing.T) {
	mockRepo := new(MockUserRepository)
	uc := usecase.NewUserUsecase(mockRepo)

	users := []*entity.User{
		{ID: uuid.New(), Email: "user1@example.com"},
		{ID: uuid.New(), Email: "user2@example.com"},
	}

	mockRepo.On("List", mock.Anything, 20, 0).Return(users, nil)

	result, err := uc.List(context.Background(), 20, 0)

	require.NoError(t, err)
	assert.Len(t, result, 2)
	assert.Equal(t, users, result)
	mockRepo.AssertExpectations(t)
}

func TestUserUsecase_VerifyPassword(t *testing.T) {
	t.Run("success", func(t *testing.T) {
		mockRepo := new(MockUserRepository)
		uc := usecase.NewUserUsecase(mockRepo)

		hashedPassword, err := bcrypt.GenerateFromPassword([]byte("password123"), bcrypt.DefaultCost)
		require.NoError(t, err)

		expectedUser := &entity.User{
			ID:       uuid.New(),
			Email:    "test@example.com",
			Password: string(hashedPassword),
		}

		mockRepo.On("GetByEmail", mock.Anything, expectedUser.Email).Return(expectedUser, nil)

		user, err := uc.VerifyPassword(context.Background(), expectedUser.Email, "password123")

		require.NoError(t, err)
		assert.Equal(t, expectedUser, user)
		mockRepo.AssertExpectations(t)
	})

	t.Run("invalid password", func(t *testing.T) {
		mockRepo := new(MockUserRepository)
		uc := usecase.NewUserUsecase(mockRepo)

		hashedPassword, err := bcrypt.GenerateFromPassword([]byte("password123"), bcrypt.DefaultCost)
		require.NoError(t, err)

		existingUser := &entity.User{
			ID:       uuid.New(),
			Email:    "test@example.com",
			Password: string(hashedPassword),
		}

		mockRepo.On("GetByEmail", mock.Anything, existingUser.Email).Return(existingUser, nil)

		user, err := uc.VerifyPassword(context.Background(), existingUser.Email, "wrong-password")

		assert.Nil(t, user)
		assert.ErrorIs(t, err, usecase.ErrInvalidPassword)
		mockRepo.AssertExpectations(t)
	})
}
